cameras:
  - id: "camera1"
    name: "Camera 1"
    rtsp_url: "rtsp://user:password@192.168.1.100:554/stream1"
    fps: 10
    enabled: true
    motion_enabled: true
    roi: []
    motion_threshold: 0.005
    detector:
      imgsz: 640
  - id: "camera2"
    name: "Camera 2"
    rtsp_url: "rtsp://user:password@192.168.1.101:554/stream1"
    fps: 10
    enabled: true
    motion_enabled: true
    roi: []
    motion_threshold: 0.005
    detector:
      imgsz: 640
