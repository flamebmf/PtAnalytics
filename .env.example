# ==============================================
# Настройки cam-analyzer
# Скопируйте в .env и заполните
# ==============================================

# Корень данных на хосте
DATA_ROOT=/srv/cam-analyzer
# Структура:
#   /srv/cam-analyzer/
#     frames/        — снимки объектов
#     models/        — кеш AI-моделей
#     pgdata/        — данные PostgreSQL
#     mqtt-config/   — конфиг Mosquitto
#     mqtt-data/     — persistence Mosquitto

# PostgreSQL:
#   WITH_LOCAL_PG=yes  → поднимется в том же podman pod
#   WITH_LOCAL_PG=no   → укажите внешний хост ниже
WITH_LOCAL_PG=no

# Внешний PostgreSQL (если WITH_LOCAL_PG=no)
DB_HOST=192.168.1.100
DB_PORT=5432
DB_NAME=cam
DB_USER=cam
DB_PASSWORD=change_me

# MQTT брокер — внешний хост или localhost если WITH_MQTT=yes
MQTT_HOST=192.168.1.100
MQTT_PORT=1883

# Параметры pod
POD_NAME=cam-pod
HEALTH_PORT=8090
REGISTRY=                     # registry.example.com/pltech
IMAGE_TAG=latest
WITH_BUILD=yes                # yes=сборка локально, no=pull из registry
WITH_MQTT=no        # yes — запустить Mosquitto в поде
WITH_GPU=no         # yes — пробросить nvidia GPU
WITH_SYSTEMD=no     # yes — сгенерировать systemd unit
WITH_TEST_STREAM=no # yes — проверить RTSP камеры до запуска
TZ=Europe/Moscow
