cameras:
  - id: "camera1"
    name: "Camera 1"
    rtsp_url: "rtsp://user:password@192.168.1.100:554/stream1"
    fps: 10
    enabled: true
    motion_enabled: true
    roi: []
    motion_threshold: 0.005
    lpr_enabled: true      # per-camera override for LPR (default: true)
    face_enabled: true     # per-camera override for face recognition (default: true)
    vmr_enabled: true      # per-camera override for VMR (default: true)
    enabled_classes: [person, bicycle, car, motorcycle, bus, truck]  # which classes to detect
    detector:
      imgsz: 640
      min_bbox_size: 40
      min_bbox_size_per_class: {0: 80, 2: 120, 5: 120, 7: 120}  # per YOLO class_id: person, car, bus, truck
      cross_class_iou: 0.3  # cross-class NMS: suppress lower-confidence overlapping detections of different classes
  - id: "camera2"
    name: "Camera 2"
    rtsp_url: "rtsp://user:password@192.168.1.101:554/stream1"
    fps: 10
    enabled: true
    motion_enabled: true
    roi: []
    motion_threshold: 0.005
    detector:
      imgsz: 640
